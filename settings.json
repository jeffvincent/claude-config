{
  "alwaysThinkingEnabled": true,
  "defaultMode": "plan",
  "feedbackSurveyState": {
    "lastShownTime": 1754062597340
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 /Users/jvincent/.claude/hooks/ks-link-suggestions.py",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/job-completion.sh",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/job-start.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(GH_HOST=github.com gh pr diff:*)",
      "Bash(GH_HOST=github.com gh pr list:*)",
      "Bash(GH_HOST=github.com gh pr view:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(git merge:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Read(//tmp/mcp-tool-outputs/**)"
    ],
    "deny": [
      "Read(*.pem)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash ~/.claude/statusline-anchor.sh",
    "type": "command"
  }
}
